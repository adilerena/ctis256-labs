<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <h1>Photo Album Application</h1>
    <form action="" method="post" enctype="multipart/form-data">
        <p>Tags: <input type="text" name="tags"></p>
        <p>Photo <input type="file" name="photo"></p>
        <p><button type="submit">Upload</button></p>
    </form>

    <%- error ? `<p class="error">${error}</p>` : ""%>

    <div class="container">
        <% photos.forEach(p => { %>
            <div>
                <div class="original"> <%= p["original"] %></div>
                <div class="date">
                    <%=
                    p["created_at"].toLocaleDateString("tr-TR", { day: "2-digit", month: "long", year: "numeric", hour: "2-digit", minute: "2-digit"})
                    %>
                </div>
                <img src="/uploads/<%= p[`filename`]%>">
                <div class="tags">
                    <%-
                        p["tags"].split(" ").map( t => `<span>${t}</span>`).join(" ")
                    %>
                </div>
            </div>
        <% }) %>
    </div>

</body>
</html>